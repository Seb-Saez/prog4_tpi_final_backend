COOKIE_SEGURE=false
# token de 32 caracteres mínimo (HS256 = 256 bits)
SECRET_KEY=<poner en el .env sino no arranca la app>
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_EMAIL=admin@foodstore.com
ADMIN_INITIAL_FULLNAME=Administrador
ADMIN_INITIAL_PASSWORD=admin123

# MercadoPago (obligatorio para pagos con MP)
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxx
MP_NOTIFICATION_URL=https://tu-ngrok-url.ngrok.io
MP_FRONTEND_URL=http://localhost:5173

# Cloudinary (opcional — para subida de imágenes de productos)
CLOUDINARY_CLOUD_NAME=ejemplo_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret